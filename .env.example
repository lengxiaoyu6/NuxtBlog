# 用于加密管理员会话 Cookie，至少填写 32 个字符的随机字符串
NUXT_SESSION_PASSWORD=replace-with-at-least-32-characters-random-string

# Prisma 连接 MySQL 的连接串；外部 MySQL 方案使用此值
DATABASE_URL=mysql://root:password@127.0.0.1:3306/nuxt-blog

# 本地运行或非 Docker 场景的媒体文件目录；相对路径会解析到项目根目录
MEDIA_STORAGE_DIR=storage/media

# 用于对限流标识、登录失败计数等安全标识进行服务端哈希
SECURITY_HASH_SALT=replace-with-random-security-hash-salt

# Cloudflare Turnstile 服务端校验密钥；启用相关人机校验时填写
TURNSTILE_SECRET_KEY=

# IP 归属地解析提供方，默认使用 ip2region
IP_REGION_PROVIDER=ip2region

# ip2region IPv4 数据库文件路径
IP_REGION_DB_V4_PATH=server/resources/ip2region/ip2region_v4.xdb

# ip2region IPv6 数据库文件路径
IP_REGION_DB_V6_PATH=server/resources/ip2region/ip2region_v6.xdb

# 以下变量供 Docker Compose 内置 MySQL 方案使用

# MySQL root 账号口令，用于数据库初始化与健康检查
MYSQL_ROOT_PASSWORD=replace-with-root-password

# 内置 MySQL 方案使用的数据库名称
MYSQL_DATABASE=nuxt-blog

# 内置 MySQL 方案使用的数据库业务账号
MYSQL_USER=nuxtblog

# 内置 MySQL 方案使用的数据库业务账号口令
MYSQL_PASSWORD=replace-with-db-password

# Docker 容器内的媒体文件目录，同时也是媒体卷挂载目标
DOCKER_MEDIA_STORAGE_DIR=/app/storage/media

# 应用容器等待数据库就绪的最大重试次数
DATABASE_WAIT_MAX_ATTEMPTS=30

# 应用容器每次等待数据库重试前的休眠秒数
DATABASE_WAIT_SLEEP_SECONDS=3

# 以下变量用于 Docker 镜像构建阶段

# 构建镜像时替换 Debian 软件源的镜像地址，留空时使用官方源
APT_MIRROR=

# 构建镜像时指定 npm registry，同时影响 Corepack 获取 pnpm 与依赖安装
NPM_REGISTRY=
